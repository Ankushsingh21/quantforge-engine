    }
  ]
},
{
  "collapsed": false,
  "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 14
  },
  "id": 102,
  "title": "Portfolio & PnL",
  "type": "row"
},
{
