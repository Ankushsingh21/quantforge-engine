  "targets": [
    {
      "datasource": {
        "type": "prometheus"
      },
      "expr": "quantforge_strategy_unrealized_pnl",
      "legendFormat": "{{strategy_id}}"
    }
  ]
},
{
  "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
  },
  "fieldConfig": {
    "defaults": {
      "unit": "currencyINR",
      "color": {
