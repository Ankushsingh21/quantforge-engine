{
  "__inputs": [],
  "__requires": [],

  "annotations": {
    "list": []
  },

  "description": "QuantForge Live Trading Dashboard",

  "editable": true,
  "graphTooltip": 1,
  "id": null,

  "panels": [

    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Market Data",
      "type": "row"
    },

    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },

      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      },

      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 1
      },

      "id": 1,

      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },

      "title": "Tick Rate (ticks/s)",

      "type": "stat",

      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },

          "expr": "rate(quantforge_ticks_total[10s])",

          "legendFormat": "{{symbol}}"
        }
      ]
    },

    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },

      "fieldConfig": {
        "defaults": {
          "unit": "µs"
        }
      },

      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 1
      },

      "id": 2,

      "options": {
        "bucketOffset": 0
      },

      "title": "Tick-to-Order Latency (µs)",

      "type": "histogram",

      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },

          "expr": "quantforge_tick_to_order_latency_us_bucket",

          "legendFormat": "{{le}}"
        }
      ]
    },

    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },

      "fieldConfig": {
        "defaults": {
          "unit": "short",

          "color": {
            "mode": "thresholds"
          },

          "thresholds": {
            "mode": "absolute",

            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },

      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 1
      },

      "id": 3,

      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },

        "textMode": "value_and_name",

        "colorMode": "background"
      },

      "title": "Market Data Reconnects",

      "type": "stat",

      "targets": [
        {
          "datasource": {
            "type": "prometheus"
          },

          "expr": "quantforge_md_reconnects_total",

          "legendFormat": "Reconnects"
        }
      ]
    },

    {
      "collapsed": false,

      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },

      "id": 101,

      "title": "Orders & Fills",

      "type": "row"
    },

   {
  "datasource": {
    "type": "prometheus",
